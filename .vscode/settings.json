    "chat.tools.terminal.autoApprove": {
        "/^Get-ChildItem \"e:\\\\Projects\\\\GameWithAI\\\\SamepleAICore\\\\Assets\\\\Scripts\" -Recurse -Filter \"\\*\\.cs\" \\| ForEach-Object \\{ \\$meta = \\$_\\.FullName \\+ \"\\.meta\"; if \\(-not \\(Test-Path \\$meta\\)\\) \\{ Write-Output \\$_\\.FullName \\} \\}$/": {
            "approve": true,
            "matchCommandLine": true
        },
        "Test-Path": true,
        "ForEach-Object": true,
